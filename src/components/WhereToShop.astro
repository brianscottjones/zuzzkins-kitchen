---
const markets = [
  {
    name: "Kingston Springs Farmers Market",
    schedule: "Saturdays, 8am–1pm · Seasonal",
    note: "Our home market. Come say hello.",
  },
  {
    name: "Nashville Farmers Market",
    schedule: "Select Saturdays",
    note: "Check Instagram for dates.",
  },
  {
    name: "Cheatham County Fall Festival",
    schedule: "October · Annual",
    note: "Ashland City, TN",
  },
];
---

<section class="shop" id="shop">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    <span class="eyebrow">Come Find Us</span>
    <h2 class="shop__title">Where to Shop</h2>
    <p class="shop__intro">
      We sell at local farmers markets and festivals around Middle Tennessee. Follow us on Instagram or check back here for updated dates.
    </p>

    <ul class="shop__list">
      {markets.map((m) => (
        <li class="shop__item">
          <div class="shop__item-main">
            <span class="shop__item-name">{m.name}</span>
            <span class="shop__item-schedule">{m.schedule}</span>
          </div>
          <p class="shop__item-note script">{m.note}</p>
        </li>
      ))}
    </ul>

    <div class="shop__cta">
      <p>Can't make it to a market? We take local orders — just reach out.</p>
      <a href="#orders" class="btn btn-rose">Place an Order</a>
    </div>

  </div>
</section>

<style>
  .shop {
    padding-block: var(--section-pad);
    background: var(--color-white);
  }

  .shop__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 1rem;
  }

  .shop__intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  /* List */
  .shop__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .shop__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .shop__item-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .shop__item-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brown);
  }

  .shop__item-schedule {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .shop__item-note {
    font-family: var(--font-script);
    font-size: 0.95rem;
    color: var(--color-rose-dark);
    text-align: right;
    flex-shrink: 0;
  }

  /* CTA */
  .shop__cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .shop__cta p {
    font-size: 1rem;
    color: var(--color-text-muted);
    flex: 1;
    min-width: 200px;
  }

  @media (max-width: 540px) {
    .shop__item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .shop__item-note { text-align: left; }

    .shop__cta { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
  }
</style>
