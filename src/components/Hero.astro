---
---

<section class="hero" id="hero">
  <!-- Decorative bg blobs -->
  <div class="hero__blob hero__blob--rose" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--sage" aria-hidden="true"></div>

  <div class="hero__inner container">
    <!-- Mascot / Logo area -->
    <div class="hero__mascot" aria-hidden="true">
      <div class="mascot-frame">
        <!-- SVG Opossum placeholder — skeleton opossum with flower crown -->
        <svg viewBox="0 0 220 260" xmlns="http://www.w3.org/2000/svg" class="mascot-svg" role="img" aria-label="Zuzzkin's Kitchen mascot: a skeleton opossum with a flower crown">
          <!-- Body -->
          <ellipse cx="110" cy="180" rx="55" ry="65" fill="#F0E8DC" stroke="#9CAF88" stroke-width="2"/>
          <!-- Rib cage detail -->
          <line x1="90" y1="160" x2="130" y2="160" stroke="#C8D8BA" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="85" y1="172" x2="135" y2="172" stroke="#C8D8BA" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="87" y1="184" x2="133" y2="184" stroke="#C8D8BA" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Sternum -->
          <line x1="110" y1="152" x2="110" y2="196" stroke="#C8D8BA" stroke-width="1.5"/>

          <!-- Head -->
          <ellipse cx="110" cy="105" rx="42" ry="38" fill="#F0E8DC" stroke="#9CAF88" stroke-width="2"/>

          <!-- Skull suture lines -->
          <path d="M85 88 Q95 82 110 88 Q125 82 135 88" fill="none" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>
          <path d="M110 70 Q110 80 110 105" fill="none" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>

          <!-- Eye sockets -->
          <ellipse cx="95" cy="103" rx="10" ry="11" fill="#3D2B1F" opacity="0.85"/>
          <ellipse cx="125" cy="103" rx="10" ry="11" fill="#3D2B1F" opacity="0.85"/>
          <!-- Eye shine -->
          <circle cx="98" cy="99" r="3" fill="white" opacity="0.9"/>
          <circle cx="128" cy="99" r="3" fill="white" opacity="0.9"/>
          <!-- Sparkle in eye -->
          <circle cx="100" cy="97" r="1.5" fill="white"/>
          <circle cx="130" cy="97" r="1.5" fill="white"/>

          <!-- Snout -->
          <ellipse cx="110" cy="118" rx="18" ry="12" fill="#ECC8C8" stroke="#9CAF88" stroke-width="1.5"/>
          <!-- Nose -->
          <ellipse cx="110" cy="114" rx="5" ry="3.5" fill="#D4A0A0"/>
          <!-- Smile (skull style) -->
          <path d="M96 124 Q103 130 110 124 Q117 130 124 124" fill="none" stroke="#9CAF88" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Teeth -->
          <rect x="100" y="124" width="5" height="6" rx="1" fill="white" stroke="#9CAF88" stroke-width="0.75"/>
          <rect x="107" y="124" width="5" height="6" rx="1" fill="white" stroke="#9CAF88" stroke-width="0.75"/>
          <rect x="114" y="124" width="5" height="6" rx="1" fill="white" stroke="#9CAF88" stroke-width="0.75"/>

          <!-- Ears -->
          <ellipse cx="73" cy="75" rx="14" ry="18" fill="#F0E8DC" stroke="#9CAF88" stroke-width="2"/>
          <ellipse cx="73" cy="75" rx="8" ry="12" fill="#ECC8C8"/>
          <ellipse cx="147" cy="75" rx="14" ry="18" fill="#F0E8DC" stroke="#9CAF88" stroke-width="2"/>
          <ellipse cx="147" cy="75" rx="8" ry="12" fill="#ECC8C8"/>

          <!-- Gold hoop earring (right ear) -->
          <circle cx="158" cy="85" r="9" fill="none" stroke="#E8B84B" stroke-width="3"/>
          <circle cx="158" cy="85" r="9" fill="none" stroke="#F0C860" stroke-width="1.5" opacity="0.6"/>

          <!-- Flower Crown -->
          <!-- Stems / leaves -->
          <path d="M75 62 Q85 50 95 58" fill="none" stroke="#9CAF88" stroke-width="2"/>
          <path d="M130 60 Q140 48 148 58" fill="none" stroke="#9CAF88" stroke-width="2"/>
          <!-- Leaves -->
          <ellipse cx="82" cy="52" rx="8" ry="4" fill="#9CAF88" transform="rotate(-30 82 52)"/>
          <ellipse cx="140" cy="51" rx="8" ry="4" fill="#9CAF88" transform="rotate(30 140 51)"/>

          <!-- Flowers -->
          <!-- Flower 1 (left) — rose pink -->
          <circle cx="82" cy="57" r="10" fill="#D4A0A0"/>
          <circle cx="82" cy="57" r="5" fill="#F0C098"/>
          <circle cx="75" cy="52" r="7" fill="#ECC8C8"/>
          <circle cx="89" cy="52" r="7" fill="#ECC8C8"/>
          <circle cx="82" cy="49" r="7" fill="#ECC8C8"/>

          <!-- Flower 2 (center top) — yellow -->
          <circle cx="110" cy="48" r="11" fill="#E8D88A"/>
          <circle cx="110" cy="48" r="5.5" fill="#F0C098"/>
          <circle cx="102" cy="42" r="8" fill="#F0E4A0"/>
          <circle cx="118" cy="42" r="8" fill="#F0E4A0"/>
          <circle cx="110" cy="38" r="8" fill="#F0E4A0"/>
          <circle cx="102" cy="55" r="7" fill="#F0E4A0"/>
          <circle cx="118" cy="55" r="7" fill="#F0E4A0"/>

          <!-- Flower 3 (right) — peach/sky -->
          <circle cx="138" cy="57" r="10" fill="#A8C8D8"/>
          <circle cx="138" cy="57" r="5" fill="#ECC8C8"/>
          <circle cx="131" cy="52" r="7" fill="#C8E0EC"/>
          <circle cx="145" cy="52" r="7" fill="#C8E0EC"/>
          <circle cx="138" cy="49" r="7" fill="#C8E0EC"/>

          <!-- Tiny flower accents -->
          <circle cx="95" cy="62" r="5" fill="#F0C098"/>
          <circle cx="125" cy="62" r="5" fill="#C8D8BA"/>

          <!-- Arms -->
          <path d="M58 165 Q40 180 48 200" fill="none" stroke="#F0E8DC" stroke-width="12" stroke-linecap="round"/>
          <path d="M58 165 Q40 180 48 200" fill="none" stroke="#9CAF88" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Hand -->
          <ellipse cx="50" cy="204" rx="8" ry="6" fill="#F0E8DC" stroke="#9CAF88" stroke-width="1.5"/>

          <path d="M162 165 Q180 180 172 200" fill="none" stroke="#F0E8DC" stroke-width="12" stroke-linecap="round"/>
          <path d="M162 165 Q180 180 172 200" fill="none" stroke="#9CAF88" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Hand holding a tiny jar -->
          <ellipse cx="170" cy="204" rx="8" ry="6" fill="#F0E8DC" stroke="#9CAF88" stroke-width="1.5"/>
          <!-- Jam jar -->
          <rect x="162" y="206" width="16" height="18" rx="3" fill="#D4A0A0" stroke="#9CAF88" stroke-width="1.5"/>
          <rect x="164" y="203" width="12" height="5" rx="1" fill="#9CAF88"/>
          <ellipse cx="170" cy="215" rx="5" ry="3" fill="#B8736D" opacity="0.5"/>

          <!-- Legs / paws -->
          <ellipse cx="90" cy="242" rx="14" ry="8" fill="#F0E8DC" stroke="#9CAF88" stroke-width="1.5"/>
          <ellipse cx="130" cy="242" rx="14" ry="8" fill="#F0E8DC" stroke="#9CAF88" stroke-width="1.5"/>
          <!-- Toe lines -->
          <line x1="82" y1="244" x2="80" y2="248" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>
          <line x1="90" y1="246" x2="90" y2="251" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>
          <line x1="98" y1="244" x2="100" y2="248" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>
          <line x1="122" y1="244" x2="120" y2="248" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>
          <line x1="130" y1="246" x2="130" y2="251" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>
          <line x1="138" y1="244" x2="140" y2="248" stroke="#C8D8BA" stroke-width="1" stroke-linecap="round"/>

          <!-- Tail (peeking from behind) -->
          <path d="M162 220 Q195 215 200 240 Q205 260 185 255" fill="none" stroke="#C8D8BA" stroke-width="5" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <!-- Text content -->
    <div class="hero__content">
      <span class="hero__eyebrow script">From Kingston Springs, TN</span>

      <h1 class="hero__title">
        <span class="hero__title-script script">Zuzzkin's</span>
        <span class="hero__title-main">Kitchen</span>
      </h1>

      <div class="hero__tagline">
        <span class="script">Always Homemade</span>
        <span class="tagline-dot" aria-hidden="true">✦</span>
        <span class="script">Homemade Everything</span>
      </div>

      <p class="hero__desc">
        Handcrafted cakes, fresh-baked goods, and small-batch preserves, pickles, and jams —
        made with love right here in Kingston Springs. Every jar, every slice, every treat
        is made from scratch the old-fashioned way.
      </p>

      <div class="hero__products">
        <span class="product-tag">🎂 Cakes</span>
        <span class="product-tag">🫙 Preserves</span>
        <span class="product-tag">🥒 Pickles</span>
        <span class="product-tag">🍓 Jams</span>
      </div>

      <div class="hero__ctas">
        <a href="#orders" class="btn btn-primary">Place an Order</a>
        <a href="#shop" class="btn btn-outline">Where to Find Us</a>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#F0E8DC"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    padding-top: 5rem;
    padding-bottom: 6rem;
    background: linear-gradient(160deg, var(--color-cream) 0%, #F5EDDF 40%, #EFE0D5 100%);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Decorative blobs */
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.35;
    pointer-events: none;
  }

  .hero__blob--rose {
    width: clamp(300px, 50vw, 600px);
    height: clamp(300px, 50vw, 600px);
    background: var(--color-rose-light);
    top: -10%;
    right: -10%;
  }

  .hero__blob--sage {
    width: clamp(200px, 35vw, 400px);
    height: clamp(200px, 35vw, 400px);
    background: var(--color-sage-light);
    bottom: 10%;
    left: -5%;
  }

  .hero__inner {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    position: relative;
    z-index: 1;
    padding-top: clamp(2rem, 5vw, 4rem);
  }

  /* Mascot */
  .mascot-frame {
    background: linear-gradient(135deg, var(--color-bone) 0%, var(--color-cream) 100%);
    border: 3px solid var(--color-sage-light);
    border-radius: 50%;
    padding: 2rem;
    aspect-ratio: 1;
    max-width: 380px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-soft), inset 0 0 40px rgba(156, 175, 136, 0.1);
    position: relative;
  }

  .mascot-frame::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 2px dashed var(--color-rose-light);
    animation: spin 60s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .mascot-svg {
    width: 100%;
    max-width: 240px;
    height: auto;
    filter: drop-shadow(0 4px 12px rgba(61, 43, 31, 0.15));
  }

  /* Text content */
  .hero__eyebrow {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-sage-dark);
    display: block;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  .hero__title-script {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--color-rose-dark);
    line-height: 0.9;
    display: block;
  }

  .hero__title-main {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 900;
    color: var(--color-brown);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero__tagline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-script);
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .tagline-dot {
    color: var(--color-rose);
    font-size: 0.8em;
  }

  .hero__desc {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--color-text);
    max-width: 500px;
    margin-bottom: 1.75rem;
    line-height: 1.8;
  }

  .hero__products {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .product-tag {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    background: var(--color-bone);
    border: 1.5px solid var(--color-rose-light);
    color: var(--color-brown);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    letter-spacing: 0.03em;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Wave */
  .hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    line-height: 0;
  }

  .hero__wave svg { width: 100%; height: 100%; }

  /* Responsive */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__mascot { order: -1; }

    .mascot-frame { max-width: 280px; }

    .hero__tagline { justify-content: center; }

    .hero__desc { margin-inline: auto; }

    .hero__products { justify-content: center; }

    .hero__ctas { justify-content: center; }
  }
</style>
