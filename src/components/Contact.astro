---
interface Props {
  contactIntro: string;
  contactEmail?: string;
}

const { contactIntro } = Astro.props;
---

<section class="contact" id="contact">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    
    <h2 class="contact__title">Get in Touch</h2>
    <p class="contact__intro">
      {contactIntro}
    </p>

    <!-- Contact form — action will be updated with Formspree endpoint once email is set up -->
    <form class="contact__form" id="contactForm" action="https://formsubmit.co/hello@zuzzkins.com" method="POST" novalidate>

      <input type="hidden" name="_subject" value="New message from Zuzzkin's Kitchen website" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value="https://zuzzkins.com" />
      <input type="text" name="_honey" style="display:none" />

      <div class="form-row">
        <div class="form-group">
          <label for="c-name">Name <span class="req">*</span></label>
          <input type="text" id="c-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="c-email">Email <span class="req">*</span></label>
          <input type="email" id="c-email" name="email" placeholder="jane@example.com" required autocomplete="email" />
        </div>
      </div>

      <div class="form-group">
        <label for="c-message">Message <span class="req">*</span></label>
        <textarea id="c-message" name="message" rows="4" placeholder="What's on your mind?" required></textarea>
      </div>

      <button type="submit" class="btn btn-sage contact-submit">Send Message</button>

      <div class="contact-success" id="contactSuccess" hidden>
        <p class="script">Message received! We'll get back to you soon.</p>
      </div>

    </form>

  </div>
</section>

<style>
  .contact {
    padding-block: var(--section-pad);
    background: var(--color-white);
  }

  .contact__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 1rem;
  }

  .contact__intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  /* Form */
  .contact__form {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .contact-submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .contact-success {
    margin-top: 1.5rem;
    text-align: center;
    padding: 1.25rem;
    border: 1px solid var(--color-sage);
  }

  .contact-success p {
    font-family: var(--font-script);
    font-size: 1.3rem;
    color: var(--color-sage-dark);
  }

  @media (max-width: 540px) {
    .form-row { grid-template-columns: 1fr; }

  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const success = document.getElementById('contactSuccess')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((el) => {
      const input = el as HTMLInputElement | HTMLTextAreaElement;
      if (!input.value.trim()) {
        valid = false;
        input.style.borderColor = 'var(--color-rose-dark)';
      } else {
        input.style.borderColor = '';
      }
    });

    if (!valid) return;

    const btn = form.querySelector('.contact-submit') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;

    const action = form.getAttribute('action') || '';
    try {
      await fetch(action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });
    } catch (_) {}

    form.reset();
    btn.style.display = 'none';
    success.hidden = false;
  });
</script>
