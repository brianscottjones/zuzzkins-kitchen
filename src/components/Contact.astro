---
---

<section class="contact" id="contact">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    <span class="eyebrow">Say Hello</span>
    <h2 class="contact__title">Get in Touch</h2>
    <p class="contact__intro">
      Questions about an order? Want to carry our goods in your shop? Just want to say hi? We'd love to hear from you.
    </p>

    <!-- Contact details -->
    <ul class="contact__details">
      <li>
        <span class="contact__detail-label">Location</span>
        <span>Kingston Springs, Tennessee</span>
      </li>
      <li>
        <span class="contact__detail-label">Email</span>
        <a href="mailto:hello@zuzzkinskitchen.com">hello@zuzzkinskitchen.com</a>
      </li>

    </ul>

    <!-- Contact form -->
    <form class="contact__form" id="contactForm" novalidate>

      <div class="form-row">
        <div class="form-group">
          <label for="c-name">Name <span class="req">*</span></label>
          <input type="text" id="c-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="c-email">Email <span class="req">*</span></label>
          <input type="email" id="c-email" name="email" placeholder="jane@example.com" required autocomplete="email" />
        </div>
      </div>

      <div class="form-group">
        <label for="c-message">Message <span class="req">*</span></label>
        <textarea id="c-message" name="message" rows="4" placeholder="What's on your mind?" required></textarea>
      </div>

      <button type="submit" class="btn btn-sage contact-submit">Send Message</button>

      <div class="contact-success" id="contactSuccess" hidden>
        <p class="script">Message received! We'll get back to you soon.</p>
      </div>

    </form>

  </div>
</section>

<style>
  .contact {
    padding-block: var(--section-pad);
    background: var(--color-white);
  }

  .contact__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 1rem;
  }

  .contact__intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  /* Details */
  .contact__details {
    list-style: none;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .contact__details li {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding-block: 1rem;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .contact__detail-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    min-width: 90px;
    flex-shrink: 0;
  }

  .contact__details a {
    color: var(--color-rose-dark);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .contact__details a:hover {
    color: var(--color-brown);
  }

  /* Form */
  .contact__form {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .contact-submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .contact-success {
    margin-top: 1.5rem;
    text-align: center;
    padding: 1.25rem;
    border: 1px solid var(--color-sage);
  }

  .contact-success p {
    font-family: var(--font-script);
    font-size: 1.3rem;
    color: var(--color-sage-dark);
  }

  @media (max-width: 540px) {
    .form-row { grid-template-columns: 1fr; }

    .contact__details li {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const success = document.getElementById('contactSuccess')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((el) => {
      const input = el as HTMLInputElement | HTMLTextAreaElement;
      if (!input.value.trim()) {
        valid = false;
        input.style.borderColor = 'var(--color-rose-dark)';
      } else {
        input.style.borderColor = '';
      }
    });

    if (!valid) return;

    const btn = form.querySelector('.contact-submit') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;

    await new Promise(r => setTimeout(r, 1000));

    form.reset();
    btn.style.display = 'none';
    success.hidden = false;
  });
</script>
