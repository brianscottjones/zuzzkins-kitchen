---
export const prerender = false;
import { checkAuth } from '../../lib/auth';
import { readContent } from '../../lib/content';

if (!checkAuth(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const content = readContent();
const { site, stops, photos } = content;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Zuzzkin's Kitchen</title>
  <link rel="icon" type="image/jpeg" href="/logo.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Dancing+Script:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --color-cream: #FFF8F0;
      --color-white: #FFFFFF;
      --color-bone: #F5EDE0;
      --color-rose: #D4A0A0;
      --color-rose-dark: #B8736D;
      --color-rose-light: #EDD8D8;
      --color-sage: #9CAF88;
      --color-sage-dark: #7A9066;
      --color-brown: #3D2B1F;
      --color-text: #3D2B1F;
      --color-text-muted: #9A7A6A;
      --color-border: #EDE0D4;
      --color-danger: #c0392b;
      --font-heading: 'Playfair Display', Georgia, serif;
      --font-script: 'Dancing Script', cursive;
      --font-body: 'Lato', 'Helvetica Neue', sans-serif;
    }
    body {
      font-family: var(--font-body);
      background: var(--color-cream);
      color: var(--color-text);
      line-height: 1.6;
      min-height: 100svh;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── Header ── */
    .admin-header {
      background: var(--color-brown);
      color: var(--color-cream);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .admin-header__brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .admin-header__logo {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      object-fit: cover;
    }
    .admin-header__title {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-cream);
    }
    .admin-header__sub {
      font-family: var(--font-script);
      font-size: 0.85rem;
      color: var(--color-rose);
    }
    .admin-header__actions {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .header-link {
      color: var(--color-rose-light);
      font-size: 0.82rem;
      letter-spacing: 0.05em;
      text-decoration: underline;
      text-underline-offset: 3px;
      cursor: pointer;
      background: none;
      border: none;
      font-family: var(--font-body);
    }
    .header-link:hover { color: white; }

    /* ── Tab nav ── */
    .admin-tabs {
      background: var(--color-white);
      border-bottom: 2px solid var(--color-border);
      display: flex;
      gap: 0;
      padding: 0 2rem;
    }
    .tab-btn {
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 1rem 1.5rem;
      border: none;
      background: none;
      color: var(--color-text-muted);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      transition: all 0.2s;
    }
    .tab-btn:hover { color: var(--color-brown); }
    .tab-btn.active {
      color: var(--color-rose-dark);
      border-bottom-color: var(--color-rose-dark);
    }

    /* ── Panels ── */
    .admin-panel {
      max-width: 820px;
      margin: 2.5rem auto;
      padding: 0 1.5rem;
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Section headers ── */
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--color-border);
    }
    .section-title {
      font-family: var(--font-heading);
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--color-brown);
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 0.65rem 1.5rem;
      border: 1.5px solid currentColor;
      cursor: pointer;
      transition: all 0.2s;
      background: transparent;
      white-space: nowrap;
    }
    .btn-rose { color: var(--color-rose-dark); border-color: var(--color-rose); }
    .btn-rose:hover { background: var(--color-rose); color: white; }
    .btn-sage { color: var(--color-sage-dark); border-color: var(--color-sage); }
    .btn-sage:hover { background: var(--color-sage); color: white; }
    .btn-danger { color: var(--color-danger); border-color: var(--color-danger); }
    .btn-danger:hover { background: var(--color-danger); color: white; }
    .btn-dark { color: var(--color-brown); border-color: var(--color-brown); }
    .btn-dark:hover { background: var(--color-brown); color: var(--color-cream); }
    .btn-sm { padding: 0.4rem 0.9rem; font-size: 0.78rem; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Forms ── */
    .form-group { margin-bottom: 1.25rem; }
    label {
      display: block;
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--color-brown);
      margin-bottom: 0.35rem;
    }
    input[type="text"],
    input[type="email"],
    input[type="time"],
    select,
    textarea {
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--color-text);
      background: var(--color-white);
      border: 1px solid var(--color-border);
      padding: 0.65rem 0.9rem;
      width: 100%;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--color-rose); }
    textarea { resize: vertical; min-height: 90px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }

    /* ── Card ── */
    .card {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      padding: 1.5rem;
      margin-bottom: 1rem;
    }
    .card-actions {
      display: flex;
      gap: 0.5rem;
      margin-top: 1rem;
      justify-content: flex-end;
    }

    /* ── Stops list ── */
    .stop-row {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      padding: 1.1rem 1.25rem;
      margin-bottom: 0.6rem;
      display: grid;
      grid-template-columns: 32px 90px 1fr auto auto;
      align-items: center;
      gap: 1rem;
    }
    .stop-drag {
      cursor: grab;
      color: var(--color-text-muted);
      font-size: 1.1rem;
      user-select: none;
    }
    .stop-drag:active { cursor: grabbing; }
    .stop-date { font-family: var(--font-heading); font-weight: 900; font-size: 0.9rem; color: var(--color-brown); }
    .stop-day { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-muted); }
    .stop-venue { font-family: var(--font-heading); font-size: 0.95rem; color: var(--color-brown); }
    .stop-loc { font-size: 0.78rem; color: var(--color-text-muted); }
    .stop-time { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-rose-dark); text-align: right; }

    /* ── Add Stop Form ── */
    .add-form {
      background: var(--color-bone);
      border: 1px solid var(--color-border);
      padding: 1.5rem;
      margin-bottom: 2rem;
      display: none;
    }
    .add-form.open { display: block; }
    .add-form-title {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-brown);
      margin-bottom: 1.25rem;
    }
    .form-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }

    /* ── Edit modal overlay ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(61, 43, 31, 0.5);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      padding: 2rem;
      max-width: 540px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
    }
    .modal-title {
      font-family: var(--font-heading);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--color-brown);
      margin-bottom: 1.5rem;
    }
    .modal-close {
      float: right;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--color-text-muted);
      line-height: 1;
      margin-top: -0.25rem;
    }

    /* ── Photos grid ── */
    .photos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .photo-card {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      overflow: hidden;
      position: relative;
    }
    .photo-card img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      display: block;
    }
    .photo-card-body {
      padding: 0.75rem;
    }
    .photo-alt {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      margin-bottom: 0.6rem;
      line-height: 1.4;
      min-height: 2.5em;
    }
    .photo-actions {
      display: flex;
      gap: 0.4rem;
    }
    .photo-drag-handle {
      position: absolute;
      top: 6px;
      left: 6px;
      background: rgba(255,255,255,0.85);
      padding: 3px 6px;
      font-size: 0.85rem;
      cursor: grab;
      border-radius: 2px;
    }

    /* ── Upload area ── */
    .upload-zone {
      border: 2px dashed var(--color-rose);
      padding: 2.5rem;
      text-align: center;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 1rem;
    }
    .upload-zone:hover, .upload-zone.dragover { background: var(--color-rose-light); }
    .upload-zone p { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; }
    .upload-zone strong { font-family: var(--font-heading); color: var(--color-rose-dark); }
    #fileInput { display: none; }
    .upload-preview {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    .upload-preview-item {
      position: relative;
      width: 100px;
      height: 100px;
    }
    .upload-preview-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border: 1px solid var(--color-border);
    }
    .upload-preview-remove {
      position: absolute;
      top: -6px;
      right: -6px;
      width: 20px;
      height: 20px;
      background: var(--color-danger);
      color: white;
      border: none;
      border-radius: 50%;
      font-size: 0.7rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ── Site info ── */
    .site-info-form {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      padding: 2rem;
    }

    /* ── Toast ── */
    .toast {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      padding: 0.85rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      z-index: 9999;
      border: 1px solid;
      transition: opacity 0.3s;
    }
    .toast.success { background: #e8f5e9; color: #2e7d32; border-color: var(--color-sage); }
    .toast.error { background: #fdecea; color: var(--color-danger); border-color: var(--color-danger); }
    .toast.hidden { opacity: 0; pointer-events: none; }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .stop-row { grid-template-columns: 32px 1fr auto; }
      .stop-date-block { display: flex; gap: 0.4rem; align-items: baseline; }
      .stop-time-cell { display: none; }
      .form-row, .form-row-3 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- Header -->
<header class="admin-header">
  <div class="admin-header__brand">
    <img src="/logo.jpg" alt="" class="admin-header__logo" />
    <div>
      <div class="admin-header__title">Kitchen Admin</div>
      <div class="admin-header__sub">Zuzzkin's Kitchen</div>
    </div>
  </div>
  <div class="admin-header__actions">
    <a href="/" target="_blank" class="header-link">View Site ↗</a>
    <button class="header-link" id="logoutBtn">Sign Out</button>
  </div>
</header>

<!-- Tabs -->
<nav class="admin-tabs">
  <button class="tab-btn active" data-tab="stops">Next Stops</button>
  <button class="tab-btn" data-tab="photos">Photos</button>
  <button class="tab-btn" data-tab="site">Site Info</button>
</nav>

<!-- Main content -->
<main class="admin-panel">

  <!-- ── STOPS TAB ── -->
  <section class="tab-panel active" id="tab-stops">
    <div class="section-header">
      <h2 class="section-title">Next Stops</h2>
      <button class="btn btn-rose" id="showAddStopBtn">+ Add Stop</button>
    </div>

    <!-- Add form -->
    <div class="add-form" id="addStopForm">
      <p class="add-form-title">Add New Stop</p>
      <div class="form-row">
        <div class="form-group">
          <label>Date (e.g. MAR 15)</label>
          <input type="text" id="new-date" placeholder="MAR 15" />
        </div>
        <div class="form-group">
          <label>Day (e.g. SAT)</label>
          <input type="text" id="new-day" placeholder="SAT" />
        </div>
      </div>
      <div class="form-group">
        <label>Venue Name</label>
        <input type="text" id="new-venue" placeholder="Kingston Springs Farmers Market" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Location</label>
          <input type="text" id="new-location" placeholder="Kingston Springs, TN" />
        </div>
        <div class="form-group">
          <label>Time</label>
          <input type="text" id="new-time" placeholder="8:00 AM" />
        </div>
      </div>
      <div class="form-actions">
        <button class="btn btn-rose" id="saveNewStopBtn">Save Stop</button>
        <button class="btn btn-dark" id="cancelAddStopBtn">Cancel</button>
      </div>
    </div>

    <!-- Stops list -->
    <div id="stopsList">
      {stops.map((stop) => (
        <div class="stop-row" data-id={stop.id}>
          <span class="stop-drag" title="Drag to reorder">⠿</span>
          <div>
            <div class="stop-date">{stop.date}</div>
            <div class="stop-day">{stop.day}</div>
          </div>
          <div>
            <div class="stop-venue">{stop.venue}</div>
            <div class="stop-loc">{stop.location}</div>
          </div>
          <div class="stop-time">{stop.time}</div>
          <div style="display:flex;gap:0.4rem;">
            <button class="btn btn-dark btn-sm edit-stop-btn" data-id={stop.id}>Edit</button>
            <button class="btn btn-danger btn-sm delete-stop-btn" data-id={stop.id}>Delete</button>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── PHOTOS TAB ── -->
  <section class="tab-panel" id="tab-photos">
    <div class="section-header">
      <h2 class="section-title">Photos</h2>
    </div>

    <!-- Upload zone -->
    <div class="upload-zone" id="uploadZone">
      <p><strong>Click to upload photos</strong></p>
      <p>or drag and drop images here</p>
      <p style="font-size:0.78rem;margin-top:0.5rem;">JPG, PNG, WEBP supported</p>
    </div>
    <input type="file" id="fileInput" accept="image/*" multiple />
    <div class="upload-preview" id="uploadPreview"></div>
    <div id="uploadAltFields"></div>
    <div id="uploadActions" style="display:none;margin-bottom:2rem;">
      <button class="btn btn-rose" id="uploadBtn">Upload Photos</button>
    </div>

    <!-- Photos grid -->
    <div class="photos-grid" id="photosGrid">
      {photos.map((photo) => (
        <div class="photo-card" data-id={photo.id}>
          <span class="photo-drag-handle" title="Drag to reorder">⠿</span>
          <img src={photo.src} alt={photo.alt} />
          <div class="photo-card-body">
            <p class="photo-alt">{photo.alt}</p>
            <div class="photo-actions">
              <button class="btn btn-dark btn-sm edit-photo-btn" data-id={photo.id} data-alt={photo.alt}>Edit Caption</button>
              <button class="btn btn-danger btn-sm delete-photo-btn" data-id={photo.id}>Remove</button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── SITE INFO TAB ── -->
  <section class="tab-panel" id="tab-site">
    <div class="section-header">
      <h2 class="section-title">Site Info</h2>
    </div>

    <form class="site-info-form" id="siteInfoForm">
      <div class="form-row">
        <div class="form-group">
          <label>Tagline</label>
          <input type="text" name="tagline" value={site.tagline} placeholder="Always Homemade" />
        </div>
        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location" value={site.location} placeholder="Kingston Springs, TN" />
        </div>
      </div>
      <div class="form-group">
        <label>Contact Email</label>
        <input type="email" name="contactEmail" value={site.contactEmail} placeholder="hello@zuzzkinskitchen.com" />
      </div>
      <div class="form-group">
        <label>"Get in Touch" Intro Text</label>
        <textarea name="contactIntro">{site.contactIntro}</textarea>
      </div>
      <div class="form-group">
        <label>Newsletter Signup Text</label>
        <textarea name="newsletterText">{site.newsletterText}</textarea>
      </div>
      <button type="submit" class="btn btn-rose" style="width:100%;padding:1rem;font-size:0.95rem;">Save Changes</button>
    </form>
  </section>

</main>

<!-- Edit Stop Modal -->
<div class="modal-overlay" id="editStopModal">
  <div class="modal">
    <button class="modal-close" id="closeEditStopModal">×</button>
    <h3 class="modal-title">Edit Stop</h3>
    <input type="hidden" id="edit-stop-id" />
    <div class="form-row">
      <div class="form-group">
        <label>Date (e.g. MAR 15)</label>
        <input type="text" id="edit-date" placeholder="MAR 15" />
      </div>
      <div class="form-group">
        <label>Day (e.g. SAT)</label>
        <input type="text" id="edit-day" placeholder="SAT" />
      </div>
    </div>
    <div class="form-group">
      <label>Venue Name</label>
      <input type="text" id="edit-venue" placeholder="Kingston Springs Farmers Market" />
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Location</label>
        <input type="text" id="edit-location" placeholder="Kingston Springs, TN" />
      </div>
      <div class="form-group">
        <label>Time</label>
        <input type="text" id="edit-time" placeholder="8:00 AM" />
      </div>
    </div>
    <div class="form-actions">
      <button class="btn btn-rose" id="saveEditStopBtn">Save Changes</button>
      <button class="btn btn-dark" id="cancelEditStopBtn">Cancel</button>
    </div>
  </div>
</div>

<!-- Edit Photo Modal -->
<div class="modal-overlay" id="editPhotoModal">
  <div class="modal">
    <button class="modal-close" id="closeEditPhotoModal">×</button>
    <h3 class="modal-title">Edit Photo Caption</h3>
    <input type="hidden" id="edit-photo-id" />
    <div class="form-group">
      <label>Caption / Alt Text</label>
      <textarea id="edit-photo-alt" rows="3" placeholder="Describe this photo…"></textarea>
    </div>
    <div class="form-actions">
      <button class="btn btn-rose" id="saveEditPhotoBtn">Save Caption</button>
      <button class="btn btn-dark" id="cancelEditPhotoBtn">Cancel</button>
    </div>
  </div>
</div>

<!-- Toast notification -->
<div class="toast hidden" id="toast"></div>

<script>
// ── Utilities ────────────────────────────────────────────────
function showToast(msg: string, type = 'success') {
  const t = document.getElementById('toast')!;
  t.textContent = msg;
  t.className = `toast ${type}`;
  setTimeout(() => t.classList.add('hidden'), 3000);
}

function closeModal(el: HTMLElement) {
  el.classList.remove('open');
}

function openModal(el: HTMLElement) {
  el.classList.add('open');
}

// ── Logout ───────────────────────────────────────────────────
document.getElementById('logoutBtn')!.addEventListener('click', async () => {
  await fetch('/api/auth/logout', { method: 'POST' });
  window.location.href = '/admin/login';
});

// ── Tab switching ─────────────────────────────────────────────
const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

tabBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    tabBtns.forEach(b => b.classList.remove('active'));
    tabPanels.forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(`tab-${btn.dataset.tab}`)!.classList.add('active');
  });
});

// ════════════════════════════════════════════════════════════
// STOPS
// ════════════════════════════════════════════════════════════

// Show/hide add form
const showAddStopBtn = document.getElementById('showAddStopBtn')!;
const addStopForm = document.getElementById('addStopForm')!;
const cancelAddStopBtn = document.getElementById('cancelAddStopBtn')!;

showAddStopBtn.addEventListener('click', () => {
  addStopForm.classList.add('open');
  showAddStopBtn.style.display = 'none';
  (document.getElementById('new-date') as HTMLInputElement).focus();
});

cancelAddStopBtn.addEventListener('click', () => {
  addStopForm.classList.remove('open');
  showAddStopBtn.style.display = '';
});

// Save new stop
document.getElementById('saveNewStopBtn')!.addEventListener('click', async () => {
  const date = (document.getElementById('new-date') as HTMLInputElement).value.trim().toUpperCase();
  const day = (document.getElementById('new-day') as HTMLInputElement).value.trim().toUpperCase();
  const venue = (document.getElementById('new-venue') as HTMLInputElement).value.trim();
  const location = (document.getElementById('new-location') as HTMLInputElement).value.trim();
  const time = (document.getElementById('new-time') as HTMLInputElement).value.trim();

  if (!date || !venue) {
    showToast('Date and Venue are required.', 'error');
    return;
  }

  const res = await fetch('/api/stops', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ date, day, venue, location, time }),
  });

  if (res.ok) {
    showToast('Stop added! Refresh to see it on the site.');
    addStopForm.classList.remove('open');
    showAddStopBtn.style.display = '';
    // Clear fields
    ['new-date','new-day','new-venue','new-location','new-time'].forEach(id => {
      (document.getElementById(id) as HTMLInputElement).value = '';
    });
    // Add to DOM
    const newStop = await res.json();
    appendStopRow(newStop);
  } else {
    showToast('Failed to save stop.', 'error');
  }
});

function appendStopRow(stop: { id: string; date: string; day: string; venue: string; location: string; time: string }) {
  const list = document.getElementById('stopsList')!;
  const div = document.createElement('div');
  div.className = 'stop-row';
  div.dataset.id = stop.id;
  div.innerHTML = `
    <span class="stop-drag" title="Drag to reorder">⠿</span>
    <div>
      <div class="stop-date">${stop.date}</div>
      <div class="stop-day">${stop.day}</div>
    </div>
    <div>
      <div class="stop-venue">${stop.venue}</div>
      <div class="stop-loc">${stop.location}</div>
    </div>
    <div class="stop-time">${stop.time}</div>
    <div style="display:flex;gap:0.4rem;">
      <button class="btn btn-dark btn-sm edit-stop-btn" data-id="${stop.id}">Edit</button>
      <button class="btn btn-danger btn-sm delete-stop-btn" data-id="${stop.id}">Delete</button>
    </div>
  `;
  list.appendChild(div);
  attachStopEvents(div);
}

// Edit stop modal
const editStopModal = document.getElementById('editStopModal')!;
document.getElementById('closeEditStopModal')!.addEventListener('click', () => closeModal(editStopModal));
document.getElementById('cancelEditStopBtn')!.addEventListener('click', () => closeModal(editStopModal));

function attachStopEvents(row: HTMLElement) {
  row.querySelector('.edit-stop-btn')?.addEventListener('click', () => {
    const id = row.dataset.id!;
    (document.getElementById('edit-stop-id') as HTMLInputElement).value = id;
    (document.getElementById('edit-date') as HTMLInputElement).value = row.querySelector('.stop-date')!.textContent || '';
    (document.getElementById('edit-day') as HTMLInputElement).value = row.querySelector('.stop-day')!.textContent || '';
    (document.getElementById('edit-venue') as HTMLInputElement).value = row.querySelector('.stop-venue')!.textContent || '';
    (document.getElementById('edit-location') as HTMLInputElement).value = row.querySelector('.stop-loc')!.textContent || '';
    (document.getElementById('edit-time') as HTMLInputElement).value = row.querySelector('.stop-time')!.textContent || '';
    openModal(editStopModal);
  });

  row.querySelector('.delete-stop-btn')?.addEventListener('click', async () => {
    const id = row.dataset.id!;
    const venue = row.querySelector('.stop-venue')?.textContent;
    if (!confirm(`Delete "${venue}"? This can't be undone.`)) return;
    const res = await fetch('/api/stops', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    if (res.ok) {
      row.remove();
      showToast('Stop deleted.');
    } else {
      showToast('Failed to delete.', 'error');
    }
  });
}

// Attach events to server-rendered rows
document.querySelectorAll<HTMLElement>('.stop-row').forEach(attachStopEvents);

// Save edit stop
document.getElementById('saveEditStopBtn')!.addEventListener('click', async () => {
  const id = (document.getElementById('edit-stop-id') as HTMLInputElement).value;
  const date = (document.getElementById('edit-date') as HTMLInputElement).value.trim().toUpperCase();
  const day = (document.getElementById('edit-day') as HTMLInputElement).value.trim().toUpperCase();
  const venue = (document.getElementById('edit-venue') as HTMLInputElement).value.trim();
  const location = (document.getElementById('edit-location') as HTMLInputElement).value.trim();
  const time = (document.getElementById('edit-time') as HTMLInputElement).value.trim();

  const res = await fetch('/api/stops', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, date, day, venue, location, time }),
  });

  if (res.ok) {
    closeModal(editStopModal);
    showToast('Stop updated! Refresh to see it on the site.');
    // Update DOM
    const row = document.querySelector<HTMLElement>(`.stop-row[data-id="${id}"]`);
    if (row) {
      row.querySelector('.stop-date')!.textContent = date;
      row.querySelector('.stop-day')!.textContent = day;
      row.querySelector('.stop-venue')!.textContent = venue;
      row.querySelector('.stop-loc')!.textContent = location;
      row.querySelector('.stop-time')!.textContent = time;
    }
  } else {
    showToast('Failed to save.', 'error');
  }
});

// ════════════════════════════════════════════════════════════
// PHOTOS
// ════════════════════════════════════════════════════════════

const uploadZone = document.getElementById('uploadZone')!;
const fileInput = document.getElementById('fileInput') as HTMLInputElement;
const uploadPreview = document.getElementById('uploadPreview')!;
const uploadAltFields = document.getElementById('uploadAltFields')!;
const uploadActions = document.getElementById('uploadActions')!;
let pendingFiles: File[] = [];

uploadZone.addEventListener('click', () => fileInput.click());

uploadZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  uploadZone.classList.add('dragover');
});
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', (e) => {
  e.preventDefault();
  uploadZone.classList.remove('dragover');
  const files = Array.from(e.dataTransfer?.files || []).filter(f => f.type.startsWith('image/'));
  addPendingFiles(files);
});

fileInput.addEventListener('change', () => {
  const files = Array.from(fileInput.files || []);
  addPendingFiles(files);
  fileInput.value = '';
});

function addPendingFiles(files: File[]) {
  pendingFiles = [...pendingFiles, ...files];
  renderPendingFiles();
}

function renderPendingFiles() {
  uploadPreview.innerHTML = '';
  uploadAltFields.innerHTML = '';

  if (pendingFiles.length === 0) {
    uploadActions.style.display = 'none';
    return;
  }

  uploadActions.style.display = 'block';

  pendingFiles.forEach((file, i) => {
    const url = URL.createObjectURL(file);

    const item = document.createElement('div');
    item.className = 'upload-preview-item';
    item.innerHTML = `
      <img src="${url}" alt="" />
      <button class="upload-preview-remove" data-idx="${i}">×</button>
    `;
    uploadPreview.appendChild(item);

    const altGroup = document.createElement('div');
    altGroup.className = 'form-group';
    altGroup.innerHTML = `
      <label>Caption for ${file.name}</label>
      <input type="text" class="upload-alt-input" data-idx="${i}" placeholder="Describe this photo…" />
    `;
    uploadAltFields.appendChild(altGroup);
  });

  uploadPreview.querySelectorAll('.upload-preview-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt((btn as HTMLElement).dataset.idx || '0');
      pendingFiles.splice(idx, 1);
      renderPendingFiles();
    });
  });
}

document.getElementById('uploadBtn')!.addEventListener('click', async () => {
  if (pendingFiles.length === 0) return;
  const btn = document.getElementById('uploadBtn') as HTMLButtonElement;
  btn.disabled = true;
  btn.textContent = 'Uploading…';

  const altInputs = document.querySelectorAll<HTMLInputElement>('.upload-alt-input');

  for (let i = 0; i < pendingFiles.length; i++) {
    const fd = new FormData();
    fd.append('file', pendingFiles[i]);
    fd.append('alt', altInputs[i]?.value || '');

    const res = await fetch('/api/photos', { method: 'POST', body: fd });
    if (res.ok) {
      const photo = await res.json();
      appendPhotoCard(photo);
    }
  }

  pendingFiles = [];
  renderPendingFiles();
  btn.disabled = false;
  btn.textContent = 'Upload Photos';
  showToast('Photos uploaded!');
});

function appendPhotoCard(photo: { id: string; src: string; alt: string }) {
  const grid = document.getElementById('photosGrid')!;
  const card = document.createElement('div');
  card.className = 'photo-card';
  card.dataset.id = photo.id;
  card.innerHTML = `
    <span class="photo-drag-handle" title="Drag to reorder">⠿</span>
    <img src="${photo.src}" alt="${photo.alt}" />
    <div class="photo-card-body">
      <p class="photo-alt">${photo.alt || '(no caption)'}</p>
      <div class="photo-actions">
        <button class="btn btn-dark btn-sm edit-photo-btn" data-id="${photo.id}" data-alt="${photo.alt}">Edit Caption</button>
        <button class="btn btn-danger btn-sm delete-photo-btn" data-id="${photo.id}">Remove</button>
      </div>
    </div>
  `;
  grid.appendChild(card);
  attachPhotoEvents(card);
}

// Edit photo modal
const editPhotoModal = document.getElementById('editPhotoModal')!;
document.getElementById('closeEditPhotoModal')!.addEventListener('click', () => closeModal(editPhotoModal));
document.getElementById('cancelEditPhotoBtn')!.addEventListener('click', () => closeModal(editPhotoModal));

function attachPhotoEvents(card: HTMLElement) {
  card.querySelector('.edit-photo-btn')?.addEventListener('click', () => {
    const id = card.dataset.id!;
    const alt = card.querySelector('.photo-alt')?.textContent || '';
    (document.getElementById('edit-photo-id') as HTMLInputElement).value = id;
    (document.getElementById('edit-photo-alt') as HTMLTextAreaElement).value = alt === '(no caption)' ? '' : alt;
    openModal(editPhotoModal);
  });

  card.querySelector('.delete-photo-btn')?.addEventListener('click', async () => {
    if (!confirm('Remove this photo? This cannot be undone.')) return;
    const id = card.dataset.id!;
    const res = await fetch('/api/photos', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    if (res.ok) {
      card.remove();
      showToast('Photo removed.');
    } else {
      showToast('Failed to remove photo.', 'error');
    }
  });
}

document.querySelectorAll<HTMLElement>('.photo-card').forEach(attachPhotoEvents);

document.getElementById('saveEditPhotoBtn')!.addEventListener('click', async () => {
  const id = (document.getElementById('edit-photo-id') as HTMLInputElement).value;
  const alt = (document.getElementById('edit-photo-alt') as HTMLTextAreaElement).value.trim();

  const res = await fetch('/api/photos', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, alt }),
  });

  if (res.ok) {
    closeModal(editPhotoModal);
    showToast('Caption saved!');
    const card = document.querySelector<HTMLElement>(`.photo-card[data-id="${id}"]`);
    if (card) {
      card.querySelector('.photo-alt')!.textContent = alt || '(no caption)';
      const editBtn = card.querySelector('.edit-photo-btn') as HTMLElement;
      if (editBtn) editBtn.dataset.alt = alt;
    }
  } else {
    showToast('Failed to save caption.', 'error');
  }
});

// ════════════════════════════════════════════════════════════
// SITE INFO
// ════════════════════════════════════════════════════════════

document.getElementById('siteInfoForm')!.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const data: Record<string, string> = {};
  new FormData(form).forEach((v, k) => { data[k] = v as string; });

  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  btn.disabled = true;
  btn.textContent = 'Saving…';

  const res = await fetch('/api/site', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data),
  });

  btn.disabled = false;
  btn.textContent = 'Save Changes';

  if (res.ok) {
    showToast('Site info saved! Changes will show on the site.');
  } else {
    showToast('Failed to save.', 'error');
  }
});

// Close modals on overlay click
[editStopModal, editPhotoModal].forEach(modal => {
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal(modal);
  });
});
</script>

</body>
</html>
