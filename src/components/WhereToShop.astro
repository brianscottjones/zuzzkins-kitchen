---
interface Stop {
  id: string;
  date: string;
  day: string;
  venue: string;
  location: string;
  time: string;
}

interface Props {
  stops: Stop[];
  newsletterText: string;
}

const { stops, newsletterText } = Astro.props;
---

<section class="dates" id="shop">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    <span class="eyebrow">Upcoming</span>
    <h2 class="dates__title">Next Stops</h2>

    {stops.length > 0 ? (
      <div class="dates__list">
        {stops.map((d) => (
          <div class="dates__row">
            <div class="dates__date-block">
              <span class="dates__month-day">{d.date}</span>
              <span class="dates__day-name">{d.day}</span>
            </div>
            <div class="dates__venue-block">
              <span class="dates__venue">{d.venue}</span>
              <span class="dates__location">{d.location}</span>
            </div>
            <div class="dates__time-block">
              <span class="dates__time">{d.time}</span>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="dates__empty">No upcoming markets — stay tuned!</p>
    )}

    <div class="dates__signup">
      <h3 class="dates__signup-heading">Join the Rat Pack</h3>
      <p class="dates__signup-text">Sign up for news and scheduling updates.</p>
      <form class="dates__form" id="ratPackForm">
        <input type="email" name="email" placeholder="Join the mailing list" required class="dates__input" />
        <button type="submit" class="btn btn-rose" id="ratPackBtn">Sign Up</button>
        <p class="ratpack-success" id="ratPackSuccess" hidden style="color: var(--color-sage-dark); font-family: var(--font-script); margin-top: 0.5rem;">Welcome to the Rat Pack! 🐀</p>
        <p class="ratpack-error" id="ratPackError" hidden style="color: var(--color-rose-dark); font-size: 0.875rem; margin-top: 0.5rem;">Something went wrong — please try again.</p>
      </form>
      <script>
        const rpForm = document.getElementById('ratPackForm') as HTMLFormElement;
        const rpBtn = document.getElementById('ratPackBtn') as HTMLButtonElement;
        const rpSuccess = document.getElementById('ratPackSuccess')!;
        const rpError = document.getElementById('ratPackError')!;
        rpForm?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const emailInput = rpForm.querySelector('input[name="email"]') as HTMLInputElement;
          if (!emailInput.value.trim()) return;
          rpBtn.textContent = 'Joining…';
          rpBtn.disabled = true;
          rpError.hidden = true;
          try {
            const res = await fetch('https://api.buttondown.com/v1/subscribers', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Token 0570d1d2-2299-4477-8f7c-6d72dd86039b'
              },
              body: JSON.stringify({ email_address: emailInput.value.trim() })
            });
            if (res.status === 201) {
              // Success
              rpForm.reset();
              rpBtn.style.display = 'none';
              rpSuccess.hidden = false;
            } else if (res.status === 400) {
              const data = await res.json().catch(() => ({}));
              if (data.code === 'email_already_exists' || data.code === 'subscriber_already_exists') {
                // Already subscribed — treat as success
                rpForm.reset();
                rpBtn.style.display = 'none';
                rpSuccess.hidden = false;
              } else {
                // Other error (blocked, invalid, etc.)
                rpBtn.textContent = 'Sign Up';
                rpBtn.disabled = false;
                rpError.hidden = false;
              }
            } else {
              rpBtn.textContent = 'Sign Up';
              rpBtn.disabled = false;
              rpError.hidden = false;
            }
          } catch (_) {
            rpBtn.textContent = 'Sign Up';
            rpBtn.disabled = false;
            rpError.hidden = false;
          }
        });
      </script>
    </div>

  </div>
</section>

<style>
  .dates {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: var(--section-pad);
    background: var(--color-white);
  }

  .dates__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 2.5rem;
  }

  .dates__list {
    display: flex;
    flex-direction: column;
    border-top: 2px solid var(--color-brown);
    margin-bottom: 2rem;
  }

  .dates__row {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .dates__row:hover {
    background: var(--color-cream);
  }

  .dates__date-block {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dates__month-day {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--color-brown);
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .dates__day-name {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .dates__venue-block {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .dates__venue {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brown);
  }

  .dates__location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .dates__time-block {
    text-align: right;
  }

  .dates__time {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-rose-dark);
  }

  .dates__empty {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: 2.5rem 1rem;
    border-top: 2px solid var(--color-brown);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .dates__signup {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .dates__signup-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 0.5rem;
  }

  .dates__signup-text {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .dates__form {
    display: flex;
    gap: 0.75rem;
    max-width: 480px;
  }

  .dates__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-brown);
  }

  .dates__input::placeholder {
    color: var(--color-text-muted);
  }

  @media (max-width: 540px) {
    .dates__row {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
    }

    .dates__time-block {
      grid-column: 2;
      text-align: left;
      margin-top: -0.5rem;
    }
  }
</style>
