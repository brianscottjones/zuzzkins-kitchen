---

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhereToShop from '../components/WhereToShop.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { readContent } from '../lib/content';
import '../styles/global.css';

const content = readContent();
const { photos, stops, site } = content;
---

<Layout
  title="Zuzzkin's Kitchen — Always Homemade | Kingston Springs, TN"
  description="Handmade cakes, baked goods, preserves, pickles, and jams from Kingston Springs, Tennessee. Always homemade, always made with love."
>
  <main>
    <Hero tagline={site.tagline} location={site.location} />

    <section class="gallery" style="padding-bottom: clamp(2rem, 4vw, 3rem);">
      <div class="slider-wrapper">
        <button class="slider__arrow slider__arrow--left" aria-label="Previous">&#8249;</button>
        <div class="slider__track" id="sliderTrack">
          {photos.map((photo: { id: string; src: string; alt: string; name?: string }) => (
            <div class="slider__slide" data-name={photo.name || ''}>
              <img src={photo.src} alt={photo.alt} loading="lazy" data-lightbox />
              {photo.name && (
                <div class="slider__label">
                  <span class="slider__label-text">{photo.name}</span>
                </div>
              )}
            </div>
          ))}
        </div>
        <button class="slider__arrow slider__arrow--right" aria-label="Next">&#8250;</button>
      </div>
      <div class="slider__dots" id="sliderDots">
        {photos.map((_: any, i: number) => (
          <button class={`slider__dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Photo ${i + 1}`}></button>
        ))}
      </div>
    </section>

    <style>
      .slider-wrapper {
        position: relative;
        max-width: 600px;
        margin: 0 auto;
        overflow: hidden;
      }
      .slider__track {
        display: flex;
        transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        cursor: grab;
        -webkit-user-select: none;
        user-select: none;
      }
      .slider__track.grabbing { cursor: grabbing; }
      .slider__slide {
        flex: 0 0 100%;
        aspect-ratio: 1;
        overflow: hidden;
        position: relative;
        cursor: pointer;
      }
      .slider__slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        pointer-events: none;
      }
      .slider__label {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 1rem 1.25rem;
        background: linear-gradient(transparent, rgba(61, 43, 31, 0.7));
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
      }
      .slider__slide.show-label .slider__label {
        opacity: 1;
      }
      .slider__label-text {
        font-family: 'Playfair Display', Georgia, serif;
        color: #FFF8F0;
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        font-weight: 600;
        font-style: italic;
        letter-spacing: 0.02em;
        text-shadow: 0 1px 4px rgba(0,0,0,0.3);
      }
      .slider__arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        background: rgba(255, 255, 255, 0.85);
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        font-size: 1.5rem;
        line-height: 1;
        color: var(--color-brown, #5c3d2e);
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);
        transition: opacity 0.2s, background 0.2s;
        opacity: 0.7;
      }
      .slider__arrow:hover { opacity: 1; background: #fff; }
      .slider__arrow--left { left: 0.75rem; }
      .slider__arrow--right { right: 0.75rem; }
      .slider__dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        padding-top: 1rem;
        max-width: 600px;
        margin: 0 auto;
      }
      .slider__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: none;
        background: var(--color-border, #ddd);
        cursor: pointer;
        padding: 0;
        transition: background 0.2s, transform 0.2s;
      }
      .slider__dot.active {
        background: var(--color-rose, #c48a8a);
        transform: scale(1.3);
      }
      @media (max-width: 540px) {
        .slider__arrow { display: none; }
        .slider-wrapper { max-width: 100%; }
      }
    </style>

    <script>
      const track = document.getElementById('sliderTrack')!;
      const wrapper = track.parentElement!;
      const slides = track.querySelectorAll('.slider__slide');
      const dots = document.querySelectorAll('.slider__dot');
      const arrowLeft = document.querySelector('.slider__arrow--left')!;
      const arrowRight = document.querySelector('.slider__arrow--right')!;
      let current = 0;
      const total = slides.length;
      let moved = false;

      function goTo(index: number, animate = true) {
        current = ((index % total) + total) % total;
        track.style.transition = animate ? 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)' : 'none';
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        resetAutoPlay();
      }

      arrowLeft.addEventListener('click', () => goTo(current - 1));
      arrowRight.addEventListener('click', () => goTo(current + 1));
      dots.forEach(dot => dot.addEventListener('click', () => goTo(Number((dot as HTMLElement).dataset.index))));

      // ── Touch swipe with live drag ──
      let startX = 0, dragOffset = 0, isDragging = false, locked = false;
      const trackWidth = () => wrapper.offsetWidth;

      track.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isDragging = true;
        locked = false;
        moved = false;
        track.style.transition = 'none';
        pauseAutoPlay();
      }, { passive: true });

      track.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const dx = e.touches[0].clientX - startX;
        const dy = e.touches[0].clientY - (e as any)._startY;

        // Lock to horizontal after first significant move
        if (!locked && Math.abs(dx) > 8) {
          locked = true;
        }
        if (!locked) return;

        moved = true;
        dragOffset = dx;
        const pct = -(current * 100) + (dx / trackWidth()) * 100;
        track.style.transform = `translateX(${pct}%)`;
      }, { passive: true });

      track.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        const dx = e.changedTouches[0].clientX - startX;
        const pct = Math.abs(dx) / trackWidth();

        if (moved && pct > 0.15) {
          goTo(dx < 0 ? current + 1 : current - 1);
        } else {
          goTo(current); // snap back
        }
        dragOffset = 0;
      });

      // ── Mouse drag (desktop) ──
      let mouseDown = false, mouseStartX = 0;

      track.addEventListener('mousedown', (e) => {
        mouseStartX = e.clientX;
        mouseDown = true;
        moved = false;
        track.style.transition = 'none';
        track.classList.add('grabbing');
        e.preventDefault();
        pauseAutoPlay();
      });

      document.addEventListener('mousemove', (e) => {
        if (!mouseDown) return;
        const dx = e.clientX - mouseStartX;
        if (Math.abs(dx) > 5) moved = true;
        const pct = -(current * 100) + (dx / trackWidth()) * 100;
        track.style.transform = `translateX(${pct}%)`;
      });

      document.addEventListener('mouseup', (e) => {
        if (!mouseDown) return;
        mouseDown = false;
        track.classList.remove('grabbing');
        const dx = e.clientX - mouseStartX;
        const pct = Math.abs(dx) / trackWidth();
        if (moved && pct > 0.15) {
          goTo(dx < 0 ? current + 1 : current - 1);
        } else {
          goTo(current);
        }
      });

      // ── Keyboard ──
      document.addEventListener('keydown', (e) => {
        if (document.getElementById('lightbox')?.getAttribute('aria-hidden') === 'false') return;
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });

      // ── Auto-play (5 seconds, pauses on interaction) ──
      let autoPlayTimer: ReturnType<typeof setInterval> | null = null;

      function startAutoPlay() {
        stopAutoPlay();
        autoPlayTimer = setInterval(() => goTo(current + 1), 5000);
      }

      function stopAutoPlay() {
        if (autoPlayTimer) { clearInterval(autoPlayTimer); autoPlayTimer = null; }
      }

      function pauseAutoPlay() { stopAutoPlay(); }
      function resetAutoPlay() { startAutoPlay(); }

      // Start auto-play on load
      startAutoPlay();

      // Pause when page is not visible
      document.addEventListener('visibilitychange', () => {
        document.hidden ? pauseAutoPlay() : startAutoPlay();
      });
    </script>

    <!-- Lightbox overlay -->
    <div id="lightbox" class="lightbox" aria-hidden="true">
      <button class="lightbox__close" aria-label="Close">&times;</button>
      <button class="lightbox__prev" aria-label="Previous">&#8249;</button>
      <button class="lightbox__next" aria-label="Next">&#8250;</button>
      <img class="lightbox__img" src="" alt="" />
    </div>

    <style>
      .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.92);
        align-items: center;
        justify-content: center;
        cursor: zoom-out;
      }
      .lightbox[aria-hidden="false"] {
        display: flex;
      }
      .lightbox__img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
        cursor: default;
      }
      .lightbox__close {
        position: absolute;
        top: 1rem;
        right: 1.5rem;
        background: none;
        border: none;
        color: #fff;
        font-size: 2.5rem;
        cursor: pointer;
        line-height: 1;
        opacity: 0.8;
        transition: opacity 0.2s;
      }
      .lightbox__close:hover { opacity: 1; }
      .lightbox__prev,
      .lightbox__next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #fff;
        font-size: 3rem;
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s;
        padding: 1rem;
      }
      .lightbox__prev:hover,
      .lightbox__next:hover { opacity: 1; }
      .lightbox__prev { left: 0.5rem; }
      .lightbox__next { right: 0.5rem; }
      .gallery__item img { cursor: zoom-in; }

      @media (max-width: 540px) {
        .lightbox__prev,
        .lightbox__next { font-size: 2rem; }
      }
    </style>

    <script>
      const lightbox = document.getElementById('lightbox')!;
      const lbImg = lightbox.querySelector('.lightbox__img') as HTMLImageElement;
      const images = Array.from(document.querySelectorAll('[data-lightbox]')) as HTMLImageElement[];
      let currentIndex = 0;

      function openLightbox(index: number) {
        currentIndex = index;
        lbImg.src = images[index].src;
        lbImg.alt = images[index].alt;
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      function navigate(dir: number) {
        currentIndex = (currentIndex + dir + images.length) % images.length;
        lbImg.src = images[currentIndex].src;
        lbImg.alt = images[currentIndex].alt;
      }

      // Tap to toggle label; double-tap opens lightbox
      let tapTimeout: ReturnType<typeof setTimeout> | null = null;
      document.querySelectorAll('.slider__slide').forEach((slide, i) => {
        slide.addEventListener('click', (e) => {
          if (moved) return;
          if (tapTimeout) {
            // Double tap — open lightbox
            clearTimeout(tapTimeout);
            tapTimeout = null;
            slide.classList.remove('show-label');
            openLightbox(i);
          } else {
            // Single tap — toggle label
            tapTimeout = setTimeout(() => {
              tapTimeout = null;
              slide.classList.toggle('show-label');
            }, 300);
          }
        });
      });
      lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
      lightbox.querySelector('.lightbox__close')!.addEventListener('click', closeLightbox);
      lightbox.querySelector('.lightbox__prev')!.addEventListener('click', (e) => { e.stopPropagation(); navigate(-1); });
      lightbox.querySelector('.lightbox__next')!.addEventListener('click', (e) => { e.stopPropagation(); navigate(1); });
      document.addEventListener('keydown', (e) => {
        if (lightbox.getAttribute('aria-hidden') === 'true') return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigate(-1);
        if (e.key === 'ArrowRight') navigate(1);
      });
    </script>

    <WhereToShop stops={stops} newsletterText={site.newsletterText} />
    <Contact
      contactIntro={site.contactIntro}
    />
  </main>
  <Footer contactEmail={site.contactEmail} />
</Layout>
