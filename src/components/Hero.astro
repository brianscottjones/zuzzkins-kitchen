---
interface Props {
  tagline: string;
  location: string;
}
const { tagline, location } = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero__inner container">

    <!-- Logo placeholder — temporary until final branding is ready -->
    <div class="hero__logo-wrap" aria-label="Zuzzkin's Kitchen placeholder logo">
      <div class="hero__logo-placeholder" role="img" aria-label="Placeholder logo">
        <span class="hero__logo-heading">placeholder</span>
      </div>
    </div>

    <p class="hero__location">{location}</p>

    <!-- Tagline -->
    <p class="hero__tagline">
      <span class="script">{tagline}</span>
    </p>

    <!-- Nav anchors -->
    <nav class="hero__nav" aria-label="Page sections">
      <a href="#shop" class="hero__nav-link">Next Stops</a>
      <span class="hero__nav-dot" aria-hidden="true">·</span>
      <a href="#contact" class="hero__nav-link">Get in Touch</a>
    </nav>

  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 5rem 6rem;
    background: var(--color-cream);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  /* Logo */
  .hero__logo-wrap {
    margin-bottom: 2.5rem;
  }

  .hero__logo-placeholder {
    width: clamp(200px, 40vw, 300px);
    height: clamp(200px, 40vw, 300px);
    border-radius: 50%;
    background: var(--color-white);
    border: clamp(8px, 1.8vw, 14px) solid var(--color-rose);
    box-shadow: 0 18px 45px rgba(61, 43, 31, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    color: var(--color-brown);
    text-align: center;
    padding: 2rem;
  }

  .hero__logo-heading {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 3vw, 1.55rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.15;
    text-transform: lowercase;
    color: var(--color-brown);
  }

  /* Location */
  .hero__location {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  /* Tagline */
  .hero__tagline {
    font-family: var(--font-script);
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    color: var(--color-rose-dark);
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
  }

  /* Navigation links */
  .hero__nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__nav-link {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-brown);
    border-bottom: 1px solid var(--color-rose);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero__nav-link:hover {
    color: var(--color-rose-dark);
    border-color: var(--color-rose-dark);
  }

  .hero__nav-dot {
    color: var(--color-rose);
    font-size: 1.2rem;
    line-height: 1;
  }
</style>
