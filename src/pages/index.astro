---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhereToShop from '../components/WhereToShop.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Zuzzkin's Kitchen — Always Homemade | Kingston Springs, TN"
  description="Handmade cakes, baked goods, preserves, pickles, and jams from Kingston Springs, Tennessee. Always homemade, always made with love."
>
  <main>
    <Hero />

    <section class="product-photo">
      <div class="container">
        <img
          src="/brownies.jpg"
          alt="Stack of homemade brownies on a vintage floral plate"
          class="product-photo__img"
          width="896"
          height="1035"
        />
      </div>
    </section>

    <WhereToShop />
    <Contact />
  </main>
  <Footer />
</Layout>
