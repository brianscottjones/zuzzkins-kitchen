---
const links = [
  { href: '#photos',  label: 'Gallery' },
  { href: '#shop',    label: 'Where to Shop' },
  { href: '#orders',  label: 'Orders' },
  { href: '#contact', label: 'Get in Touch' },
];
---

<nav class="nav" id="nav">
  <div class="nav__inner container">
    <a href="#hero" class="nav__brand">
      <span class="nav__brand-script">Zuzzkin's</span>
      <span class="nav__brand-word">Kitchen</span>
    </a>

    <button class="nav__burger" id="navBurger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav__links" id="navLinks">
      {links.map(l => (
        <li><a href={l.href} class="nav__link">{l.label}</a></li>
      ))}
      <li><a href="#orders" class="btn btn-primary nav__cta">Order Now</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 100;
    background: rgba(255, 248, 240, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-bone);
    transition: box-shadow 0.3s;
  }

  .nav.scrolled {
    box-shadow: var(--shadow-soft);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.85rem;
    gap: 1rem;
  }

  .nav__brand {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    text-decoration: none;
  }

  .nav__brand-script {
    font-family: var(--font-script);
    font-size: 1.5rem;
    color: var(--color-rose-dark);
    line-height: 1;
  }

  .nav__brand-word {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-brown);
    letter-spacing: 0.03em;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav__link {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-muted);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
    letter-spacing: 0.02em;
  }

  .nav__link:hover {
    color: var(--color-rose-dark);
    background: var(--color-rose-light);
  }

  .nav__cta {
    margin-left: 0.5rem;
    font-size: 0.85rem;
    padding: 0.55rem 1.25rem;
  }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }

  .nav__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-brown);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .nav__burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav__burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav__burger { display: flex; }

    .nav__links {
      display: none;
      position: absolute;
      top: 100%;
      inset-inline: 0;
      flex-direction: column;
      align-items: flex-start;
      background: var(--color-cream);
      border-bottom: 2px solid var(--color-bone);
      padding: 1rem 1.5rem 1.5rem;
      gap: 0.25rem;
      box-shadow: var(--shadow-soft);
    }

    .nav__links.open { display: flex; }

    .nav__link { font-size: 1rem; width: 100%; }

    .nav__cta { margin-left: 0; margin-top: 0.5rem; align-self: flex-start; }
  }
</style>

<script>
  const burger = document.getElementById('navBurger')!;
  const links  = document.getElementById('navLinks')!;
  const nav    = document.getElementById('nav')!;

  burger.addEventListener('click', () => {
    const open = links.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
  });

  // Close on link click (mobile)
  links.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
    });
  });

  // Scroll shadow
  const onScroll = () => {
    nav.classList.toggle('scrolled', window.scrollY > 20);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
