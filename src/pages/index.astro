---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhereToShop from '../components/WhereToShop.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Zuzzkin's Kitchen — Always Homemade | Kingston Springs, TN"
  description="Handmade cakes, baked goods, preserves, pickles, and jams from Kingston Springs, Tennessee. Always homemade, always made with love."
>
  <main>
    <Hero />

    <section class="gallery">
      <div class="container">
        <div class="gallery__grid">
          <div class="gallery__item gallery__item--feature">
            <img src="/cake.jpg" alt="Victoria sponge cake with fresh berries and cream on a white cake stand" />
          </div>
          <div class="gallery__item gallery__item--small">
            <img src="/brownies.jpg" alt="Stack of homemade brownies on a vintage floral plate" />
          </div>
          <div class="gallery__item gallery__item--small">
            <img src="/preserves.jpg" alt="Chilli Jam, Dill Pickles, Green Tomato Chutney, and Salsa" />
          </div>
        </div>
      </div>
    </section>

    <WhereToShop />
    <Contact />
  </main>
  <Footer />
</Layout>
