---
---

<section class="orders" id="orders">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    <span class="eyebrow">Ready to Order?</span>
    <h2 class="orders__title">Place an Order</h2>
    <p class="orders__intro">
      Everything is made fresh to order. We do local pickup in Kingston Springs, TN, and can sometimes arrange delivery nearby. Jams and pickles can ship.
    </p>

    <!-- What we make -->
    <ul class="orders__offerings">
      <li>Custom Cakes &amp; Baked Goods</li>
      <li>Small-Batch Jams &amp; Preserves</li>
      <li>Pickles &amp; Relishes</li>
      <li>Gift Baskets</li>
    </ul>

    <!-- Order form -->
    <form class="orders__form" id="orderForm" novalidate>

      <div class="form-row">
        <div class="form-group">
          <label for="order-name">Your Name <span class="req">*</span></label>
          <input type="text" id="order-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="order-email">Email <span class="req">*</span></label>
          <input type="email" id="order-email" name="email" placeholder="jane@example.com" required autocomplete="email" />
        </div>
      </div>

      <div class="form-group">
        <label for="order-type">What are you ordering? <span class="req">*</span></label>
        <select id="order-type" name="orderType" required>
          <option value="" disabled selected>Select…</option>
          <option value="cake">Custom Cake</option>
          <option value="jam">Jam / Preserves</option>
          <option value="pickles">Pickles</option>
          <option value="gift">Gift Basket</option>
          <option value="mixed">Mixed order</option>
          <option value="other">Something else</option>
        </select>
      </div>

      <div class="form-group">
        <label for="order-details">Order Details <span class="req">*</span></label>
        <textarea
          id="order-details"
          name="details"
          rows="4"
          placeholder="Tell us what you'd like — flavor, size, occasion, quantities…"
          required
        ></textarea>
      </div>

      <div class="form-group">
        <label for="order-date">Needed By (if applicable)</label>
        <input type="date" id="order-date" name="neededBy" />
      </div>

      <button type="submit" class="btn btn-dark form-submit">Send Order Request</button>

      <p class="form-note">We'll reply within 24–48 hours to confirm details. Payment arranged at pickup.</p>

      <div class="form-success" id="orderSuccess" hidden>
        <p class="script">Thank you — Jess will be in touch soon!</p>
      </div>

    </form>

  </div>
</section>

<style>
  .orders {
    padding-block: var(--section-pad);
    background: var(--color-cream);
  }

  .orders__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 1rem;
  }

  .orders__intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* Offerings list */
  .orders__offerings {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    margin-bottom: 2.5rem;
    padding: 0;
  }

  .orders__offerings li {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brown);
    padding-left: 1rem;
    position: relative;
  }

  .orders__offerings li::before {
    content: '✦';
    position: absolute;
    left: 0;
    font-size: 0.6rem;
    color: var(--color-rose);
    top: 0.15em;
  }

  /* Form */
  .orders__form {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.9rem;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
  }

  .form-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.5;
  }

  .form-success {
    margin-top: 1.5rem;
    text-align: center;
    padding: 1.25rem;
    border: 1px solid var(--color-rose-light);
  }

  .form-success p {
    font-family: var(--font-script);
    font-size: 1.3rem;
    color: var(--color-rose-dark);
  }

  @media (max-width: 540px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('orderForm') as HTMLFormElement;
  const success = document.getElementById('orderSuccess')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((el) => {
      const input = el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
      if (!input.value.trim()) {
        valid = false;
        input.style.borderColor = 'var(--color-rose-dark)';
      } else {
        input.style.borderColor = '';
      }
    });

    if (!valid) return;

    const btn = form.querySelector('.form-submit') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;

    await new Promise(r => setTimeout(r, 1000));

    form.reset();
    btn.style.display = 'none';
    success.hidden = false;
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>
