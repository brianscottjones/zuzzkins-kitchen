---
interface Stop {
  id: string;
  date: string;
  day: string;
  venue: string;
  location: string;
  time: string;
}

interface Props {
  stops: Stop[];
  newsletterText: string;
}

const { stops, newsletterText } = Astro.props;
---

<section class="dates" id="shop">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    <span class="eyebrow">Upcoming</span>
    <h2 class="dates__title">Next Stops</h2>

    {stops.length > 0 ? (
      <div class="dates__list">
        {stops.map((d) => (
          <div class="dates__row">
            <div class="dates__date-block">
              <span class="dates__month-day">{d.date}</span>
              <span class="dates__day-name">{d.day}</span>
            </div>
            <div class="dates__venue-block">
              <span class="dates__venue">{d.venue}</span>
              <span class="dates__location">{d.location}</span>
            </div>
            <div class="dates__time-block">
              <span class="dates__time">{d.time}</span>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="dates__empty">No upcoming markets — stay tuned!</p>
    )}

    <div class="dates__signup">
      <form class="dates__form" action="#" method="POST">
        <input type="email" name="email" placeholder="Join the mailing list" required class="dates__input" />
        <button type="submit" class="btn btn-rose">Sign Up</button>
      </form>
    </div>

  </div>
</section>

<style>
  .dates {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: var(--section-pad);
    background: var(--color-white);
  }

  .dates__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 2.5rem;
  }

  .dates__list {
    display: flex;
    flex-direction: column;
    border-top: 2px solid var(--color-brown);
    margin-bottom: 2rem;
  }

  .dates__row {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .dates__row:hover {
    background: var(--color-cream);
  }

  .dates__date-block {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dates__month-day {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--color-brown);
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .dates__day-name {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .dates__venue-block {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .dates__venue {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brown);
  }

  .dates__location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .dates__time-block {
    text-align: right;
  }

  .dates__time {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-rose-dark);
  }

  .dates__empty {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: 2.5rem 1rem;
    border-top: 2px solid var(--color-brown);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .dates__signup {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .dates__signup-text {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .dates__form {
    display: flex;
    gap: 0.75rem;
    max-width: 480px;
  }

  .dates__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-brown);
  }

  .dates__input::placeholder {
    color: var(--color-text-muted);
  }

  @media (max-width: 540px) {
    .dates__row {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
    }

    .dates__time-block {
      grid-column: 2;
      text-align: left;
      margin-top: -0.5rem;
    }
  }
</style>
