---
const year = new Date().getFullYear();
---

<footer class="footer">
  <!-- Decorative wave top -->
  <div class="footer__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,0 L0,0 Z" fill="var(--color-bone)"/>
    </svg>
  </div>

  <div class="footer__inner container">
    <!-- Brand -->
    <div class="footer__brand">
      <p class="footer__name script">Zuzzkin's Kitchen</p>
      <p class="footer__tagline script">Always Homemade ✦ Homemade Everything</p>
      <p class="footer__location">📍 Kingston Springs, Tennessee</p>
    </div>

    <!-- Nav -->
    <nav class="footer__nav" aria-label="Footer navigation">
      <a href="#photos">Gallery</a>
      <a href="#shop">Where to Shop</a>
      <a href="#orders">Orders</a>
      <a href="#contact">Contact</a>
    </nav>

    <!-- Socials -->
    <div class="footer__social">
      <a href="https://instagram.com/zuzzkinskitchen" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.75"/>
          <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.75"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
        @zuzzkinskitchen
      </a>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>© {year} Zuzzkin's Kitchen. All rights reserved. Made with love in Tennessee.</p>
    <p class="footer__craft script">Every bite, homemade.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-brown);
    color: var(--color-bone);
    position: relative;
    padding-top: 0;
  }

  .footer__wave {
    line-height: 0;
    height: 80px;
  }

  .footer__wave svg { width: 100%; height: 100%; display: block; }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 3rem;
    align-items: start;
    padding-block: 2.5rem;
    border-bottom: 1px solid rgba(255, 248, 240, 0.15);
  }

  /* Brand */
  .footer__name {
    font-size: 2rem;
    color: var(--color-rose-light);
    margin-bottom: 0.25rem;
  }

  .footer__tagline {
    font-size: 1rem;
    color: var(--color-sage-light);
    margin-bottom: 0.5rem;
  }

  .footer__location {
    font-size: 0.85rem;
    color: var(--color-bone);
    opacity: 0.7;
  }

  /* Nav */
  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__nav a {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-bone);
    opacity: 0.75;
    letter-spacing: 0.04em;
    transition: opacity 0.2s, color 0.2s;
    text-decoration: none;
  }

  .footer__nav a:hover {
    opacity: 1;
    color: var(--color-rose-light);
  }

  /* Social */
  .footer__social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-bone);
    opacity: 0.75;
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 700;
    transition: opacity 0.2s, color 0.2s;
  }

  .social-link:hover {
    opacity: 1;
    color: var(--color-rose-light);
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.25rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer__bottom p {
    font-size: 0.8rem;
    color: var(--color-bone);
    opacity: 0.55;
    margin: 0;
  }

  .footer__craft {
    font-size: 1rem !important;
    opacity: 0.6 !important;
    color: var(--color-sage-light) !important;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      text-align: center;
    }

    .footer__nav { align-items: center; }

    .footer__social { align-items: center; }

    .footer__bottom { justify-content: center; text-align: center; }
  }
</style>
