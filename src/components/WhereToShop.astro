---
const dates = [
  {
    date: "MAR 15",
    day: "SAT",
    venue: "Kingston Springs Farmers Market",
    location: "Kingston Springs, TN",
    time: "8:00 AM",
  },
  {
    date: "MAR 22",
    day: "SAT",
    venue: "Kingston Springs Farmers Market",
    location: "Kingston Springs, TN",
    time: "8:00 AM",
  },
  {
    date: "APR 5",
    day: "SAT",
    venue: "Nashville Farmers Market",
    location: "Nashville, TN",
    time: "9:00 AM",
  },
  {
    date: "APR 12",
    day: "SAT",
    venue: "Kingston Springs Farmers Market",
    location: "Kingston Springs, TN",
    time: "8:00 AM",
  },
  {
    date: "OCT 18",
    day: "SAT",
    venue: "Cheatham County Fall Festival",
    location: "Ashland City, TN",
    time: "10:00 AM",
  },
];
---

<section class="dates" id="shop">
  <div class="container">

    <div class="divider">
      <span class="divider-symbol">✦</span>
    </div>

    <span class="eyebrow">Upcoming</span>
    <h2 class="dates__title">Tour Dates</h2>

    <div class="dates__list">
      {dates.map((d) => (
        <div class="dates__row">
          <div class="dates__date-block">
            <span class="dates__month-day">{d.date}</span>
            <span class="dates__day-name">{d.day}</span>
          </div>
          <div class="dates__venue-block">
            <span class="dates__venue">{d.venue}</span>
            <span class="dates__location">{d.location}</span>
          </div>
          <div class="dates__time-block">
            <span class="dates__time">{d.time}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="dates__note">Follow us on Instagram for last-minute pop-ups and market updates.</p>

  </div>
</section>

<style>
  .dates {
    padding-block: var(--section-pad);
    background: var(--color-white);
  }

  .dates__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-brown);
    margin-bottom: 2.5rem;
  }

  .dates__list {
    display: flex;
    flex-direction: column;
    border-top: 2px solid var(--color-brown);
    margin-bottom: 2rem;
  }

  .dates__row {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .dates__row:hover {
    background: var(--color-cream);
  }

  .dates__date-block {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dates__month-day {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--color-brown);
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .dates__day-name {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .dates__venue-block {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .dates__venue {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brown);
  }

  .dates__location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .dates__time-block {
    text-align: right;
  }

  .dates__time {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-rose-dark);
  }

  .dates__note {
    font-family: var(--font-script);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
  }

  @media (max-width: 540px) {
    .dates__row {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
    }

    .dates__time-block {
      grid-column: 2;
      text-align: left;
      margin-top: -0.5rem;
    }
  }
</style>
